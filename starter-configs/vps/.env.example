# .env.example — Variables de entorno para {{PROJECT_NAME}}
#
# Copiar a .env y llenar con tus valores reales.
# ⚠️ NUNCA commitear el .env real al repo (.gitignore lo bloquea).

# ─── App principal ──────────────────────────────────────
NODE_ENV=development            # development | production
PORT=3000

# URL pública de la app (para emails, OAuth callbacks, etc.)
APP_URL=http://localhost:3000   # En prod: https://tu-dominio.com

# ─── Database ──────────────────────────────────────────
# Local dev:    postgres://postgres:postgres@localhost:5432/{{db}}
# VPS prod:     postgres://{{DB_USER}}:{{DB_PWD}}@postgres:5432/{{DB_NAME}}
DATABASE_URL=

# ─── JWT / Auth ─────────────────────────────────────────
# Generar con: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM_NAME={{PROJECT_NAME}}
EMAIL_FROM_ADDRESS=noreply@tu-dominio.com

# ─── Pagos (Stripe) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# ─── AI / LLM ──────────────────────────────────────────
# Solo descomentar el que uses
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# ─── Storage (Backblaze B2) ─────────────────────────────
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET={{PROJECT_NAME}}-uploads

# ─── Monitoring ────────────────────────────────────────
SENTRY_DSN=

# ─── Feature flags ──────────────────────────────────────
ENABLE_BETA_FEATURES=false
DRY_RUN_MODE=false              # true = no envía emails/pagos reales
