# .env.example — Variables locales para {{PROJECT_NAME}}
#
# Copiar a .env (NO se sube a Git). Llenar con valores de DESARROLLO.

# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Database (SQLite local — sin instalar Postgres) ──
DATABASE_URL=file:./local.db

# Si preferís Postgres local en Docker:
# docker run --name postgres-local -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/{{db}}

# ─── JWT / Auth ─────────────────────────────────────────
# Generar con: openssl rand -base64 32
# (cualquier string random sirve en dev)
JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRES_IN=7d

# ─── APIs externas (opcional en local) ─────────────────
# OPENAI_API_KEY=sk-...
# RESEND_API_KEY=re_...
# STRIPE_SECRET_KEY=sk_test_...   # Solo test keys en local

# ─── Feature flags ──────────────────────────────────────
ENABLE_BETA_FEATURES=true
DRY_RUN_MODE=true               # En dev: NO enviar emails/pagos reales
